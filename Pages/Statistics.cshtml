@page
@model StatisticsModel
@{
    ViewData["Title"] = "Statistics — IMIS Network Monitor";
}

<!-- ─── Page Header ────────────────────────────────────────────────────────── -->
<div class="bg-white border-bottom py-3 px-4">
    <h1 class="fs-4 fw-bold mb-0">
        <i class="bi bi-graph-up me-2 text-primary"></i>Network Statistics
    </h1>
    <p class="text-muted small mb-0">24-hour device performance analysis and latency trends</p>
</div>

<!-- ─── Device Statistics Summary ────────────────────────────────────────────── -->
<div class="bg-light border-bottom py-4 px-4">
    <div class="container-fluid">
        <h2 class="fs-6 fw-bold mb-3">
            <i class="bi bi-bar-chart me-2"></i>24-Hour Device Statistics
        </h2>
        <div class="row g-3">
            @foreach (var device in Model.Devices)
            {
                var stats = Model.DeviceStatsMap.ContainsKey(device.Id) ? Model.DeviceStatsMap[device.Id] : null;
                var statusBadgeClass = device.Status switch
                {
                    "Online" => "bg-success",
                    "Offline" => "bg-danger",
                    "Timeout" => "bg-warning",
                    _ => "bg-secondary"
                };

                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h3 class="card-title fs-6 fw-bold mb-0">@device.Name</h3>
                                    <p class="font-monospace text-muted small mb-0">@device.IpAddress</p>
                                </div>
                                <span class="badge @statusBadgeClass rounded-pill px-2 py-1">
                                    @device.Status
                                </span>
                            </div>
                            
                            <hr class="my-2" />
                            
                            <div class="small">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-muted">Uptime (24h):</span>
                                    <span class="fw-semibold">@(stats?.UptimePercentage.ToString("F1") ?? "–")%</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-muted">Last Latency:</span>
                                    <span class="fw-semibold">@(stats?.LastLatency?.ToString() ?? "–")ms</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-muted">Avg Latency:</span>
                                    <span class="fw-semibold">@(stats?.AverageLatency?.ToString("F0") ?? "–")ms</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Tests (24h):</span>
                                    <span class="fw-semibold">@stats?.TotalTests / @(stats?.SuccessfulTests ?? 0)✓</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
}
